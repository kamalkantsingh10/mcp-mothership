# === Choose ONE authentication mode ===

# Option 1: AI Studio (easiest) — get key from https://aistudio.google.com/api-keys
IMAGEN_API_KEY=your-api-key

# Option 2: Vertex AI — requires gcloud auth and GCP project
# IMAGEN_GCP_PROJECT=your-gcp-project-id

# === Google Places MCP ===
# Get key from https://console.cloud.google.com/ — enable "Places API (New)"
GOOGLE_PLACES_API_KEY=your-places-api-key
